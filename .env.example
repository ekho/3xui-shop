# ── Несекретные значения (можно держать в .env) ──────────────────────────────
BOT_DEV_ID=123456789
BOT_SUPPORT_ID=123456789
BOT_DOMAIN=3xui-shop.com
BOT_ADMINS=123456789,987654321

# Прокси-поддержка (опц.): отдельный support-бот пересылает сообщения юзеров в топики
# супергруппы-форума и ответы операторов обратно. Требуются ОБА значения:
#   SUPPORT_BOT_TOKEN — токен второго бота (секрет! в prod — через ./secrets/support_bot_token.txt);
#   SUPPORT_GROUP_ID  — id супергруппы с включёнными Topics (отрицательное число, -100...),
#                       support-бот должен быть её админом с правом can_manage_topics.
# Без них кнопка «Связаться» ведёт в личку BOT_SUPPORT_ID, как раньше.
# SUPPORT_GROUP_ID=-1001234567890

# Режим получения апдейтов: True (по умолчанию) — вебхук (нужны публичный BOT_DOMAIN и
# reverse-proxy с TLS перед ботом, см. DEPLOYMENT.md); False — long-polling (getUpdates):
# бот сам забирает апдейты, публичный домен/вебхук/TLS НЕ нужны.
# Удобно с собственным telegram-bot-api, где вебхук упирается в резолвинг домена.
# BOT_USE_WEBHOOK=False

# Кастомный Telegram Bot API (опц.): локальный сервер telegram-bot-api или зеркало.
# Значение — базовый URL (scheme+host[:port]), БЕЗ /bot<token>. Пусто → https://api.telegram.org.
# TELEGRAM_API_URL=http://telegram-bot-api:8081
# TELEGRAM_API_IS_LOCAL=True   # только для self-hosted сервера в режиме --local (файлы на его диске)

XUI_USERNAME=admin

# Апрув-гейт (G1): новые юзеры ждут подтверждения админа. False → как в stock.
SHOP_APPROVAL_REQUIRED=True

# Платёжки: Stars вкл, официальный эквайринг выкл (G7).
SHOP_PAYMENT_STARS_ENABLED=True
SHOP_PAYMENT_CRYPTOMUS_ENABLED=False
SHOP_PAYMENT_YOOKASSA_ENABLED=False
SHOP_PAYMENT_YOOMONEY_ENABLED=False

# ── Секреты (G10) ─────────────────────────────────────────────────────────────
# В production передаются через docker compose secrets — НЕ в .env.
# Создайте файлы (см. README):
#   ./secrets/bot_token.txt        (BOT_TOKEN)
#   ./secrets/xui_password.txt     (XUI_PASSWORD)
#   ./secrets/webhook_secret.txt   (WEBHOOK_SECRET; A-Za-z0-9_-, длина 1..256)
# Опционально: cryptomus_api_key.txt, cryptomus_merchant_id.txt, manual_card_details.txt
#
# Для локального запуска БЕЗ docker secrets секреты можно задать переменными напрямую
# (config.py читает <NAME>, если <NAME>_FILE отсутствует):
# BOT_TOKEN="1234567890:qwerty"
# XUI_PASSWORD=admin
# WEBHOOK_SECRET=change-me-long-random-string
